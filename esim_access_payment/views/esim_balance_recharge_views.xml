<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════
         充值记录 - 列表视图
         ══════════════════════════════════════════════════════ -->
    <record id="view_esim_balance_recharge_list" model="ir.ui.view">
        <field name="name">esim.balance.recharge.list</field>
        <field name="model">esim.balance.recharge</field>
        <field name="arch" type="xml">
            <list string="在线充值记录" default_order="create_date desc">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="option_id" optional="show"/>
                <field name="amount" sum="合计"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="state"
                       widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'pending'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="create_date" string="创建时间"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         充值记录 - 表单视图
         ══════════════════════════════════════════════════════ -->
    <record id="view_esim_balance_recharge_form" model="ir.ui.view">
        <field name="name">esim.balance.recharge.form</field>
        <field name="model">esim.balance.recharge</field>
        <field name="arch" type="xml">
            <form string="在线充值">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="True"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="option_id"/>
                            <field name="amount"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="balance_log_id"/>
                            <field name="create_date" string="创建时间"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="支付交易" name="transactions">
                            <field name="transaction_ids" readonly="True">
                                <list>
                                    <field name="reference"/>
                                    <field name="provider_id"/>
                                    <field name="amount"/>
                                    <field name="state"
                                           widget="badge"
                                           decoration-info="state == 'draft'"
                                           decoration-warning="state == 'pending'"
                                           decoration-success="state in ('authorized', 'done')"
                                           decoration-danger="state in ('cancel', 'error')"/>
                                    <field name="create_date" string="创建时间"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         充值记录 - 搜索视图
         ══════════════════════════════════════════════════════ -->
    <record id="view_esim_balance_recharge_search" model="ir.ui.view">
        <field name="name">esim.balance.recharge.search</field>
        <field name="model">esim.balance.recharge</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <filter name="filter_done" string="已完成"
                        domain="[('state', '=', 'done')]"/>
                <filter name="filter_pending" string="待支付"
                        domain="[('state', '=', 'pending')]"/>
                <filter name="filter_cancelled" string="已取消"
                        domain="[('state', '=', 'cancelled')]"/>
                <separator string="分组"/>
                <group>
                    <filter name="group_partner" string="客户"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_state" string="状态"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         充值记录 - 动作
         ══════════════════════════════════════════════════════ -->
    <record id="action_esim_balance_recharge" model="ir.actions.act_window">
        <field name="name">在线充值记录</field>
        <field name="res_model">esim.balance.recharge</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                暂无在线充值记录
            </p>
            <p>客户通过门户在线充值后，记录将显示在此处。</p>
        </field>
    </record>

</odoo>
