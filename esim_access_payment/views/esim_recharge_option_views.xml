<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════
         充值档位 - 列表视图
         ══════════════════════════════════════════════════════ -->
    <record id="view_esim_recharge_option_list" model="ir.ui.view">
        <field name="name">esim.recharge.option.list</field>
        <field name="model">esim.recharge.option</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="amount"/>
                <field name="currency_id"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         充值档位 - 表单视图
         ══════════════════════════════════════════════════════ -->
    <record id="view_esim_recharge_option_form" model="ir.ui.view">
        <field name="name">esim.recharge.option.form</field>
        <field name="model">esim.recharge.option</field>
        <field name="arch" type="xml">
            <form string="充值档位">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="amount"/>
                        </group>
                        <group>
                            <field name="currency_id"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         充值档位 - 动作
         ══════════════════════════════════════════════════════ -->
    <record id="action_esim_recharge_option" model="ir.actions.act_window">
        <field name="name">充值档位</field>
        <field name="res_model">esim.recharge.option</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                创建充值档位
            </p>
            <p>配置门户客户可选择的预设充值金额。</p>
        </field>
    </record>

</odoo>
