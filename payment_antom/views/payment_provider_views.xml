<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">Antom Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <group invisible="code != 'antom'">
                    <field name="antom_client_id"
                           string="Client ID"
                           required="code == 'antom' and state != 'disabled'"/>
                    <field name="antom_gateway_region"
                           string="Gateway Region"
                           required="code == 'antom' and state != 'disabled'"/>
                    <field name="antom_merchant_private_key"
                           string="Merchant Private Key"
                           required="code == 'antom' and state != 'disabled'"
                           widget="text"/>
                    <field name="antom_public_key"
                           string="Antom Public Key"
                           required="code == 'antom' and state != 'disabled'"
                           widget="text"/>
                </group>
            </group>
        </field>
    </record>

</odoo>
