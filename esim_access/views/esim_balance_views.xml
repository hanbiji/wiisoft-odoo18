<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════
         余额变动记录：列表视图
         ══════════════════════════════════════════════════════ -->
    <record id="view_esim_balance_log_list" model="ir.ui.view">
        <field name="name">esim.balance.log.list</field>
        <field name="model">esim.balance.log</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0"
                  decoration-success="type == 'topup'"
                  decoration-danger="type == 'consume'"
                  decoration-info="type == 'refund'">
                <field name="name"/>
                <field name="create_date" string="时间"/>
                <field name="partner_id"/>
                <field name="type" widget="badge"
                       decoration-success="type == 'topup'"
                       decoration-danger="type == 'consume'"
                       decoration-info="type == 'refund'"/>
                <field name="amount"/>
                <field name="balance_before"/>
                <field name="balance_after"/>
                <field name="description"/>
                <field name="order_id" optional="show"/>
                <field name="operator_id"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         余额变动记录：表单视图
         ══════════════════════════════════════════════════════ -->
    <record id="view_esim_balance_log_form" model="ir.ui.view">
        <field name="name">esim.balance.log.form</field>
        <field name="model">esim.balance.log</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="变动信息">
                            <field name="partner_id"/>
                            <field name="type"/>
                            <field name="amount"/>
                            <field name="description"/>
                        </group>
                        <group string="余额变化">
                            <field name="balance_before"/>
                            <field name="balance_after"/>
                            <field name="order_id"/>
                            <field name="operator_id"/>
                            <field name="create_date" string="操作时间"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         余额变动记录：搜索视图
         ══════════════════════════════════════════════════════ -->
    <record id="view_esim_balance_log_search" model="ir.ui.view">
        <field name="name">esim.balance.log.search</field>
        <field name="model">esim.balance.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <filter name="filter_topup" string="充值" domain="[('type', '=', 'topup')]"/>
                <filter name="filter_consume" string="消费" domain="[('type', '=', 'consume')]"/>
                <filter name="filter_refund" string="退款" domain="[('type', '=', 'refund')]"/>
                <separator/>
                <group expand="0" string="分组">
                    <filter name="group_partner" string="客户" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_type" string="类型" context="{'group_by': 'type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         余额变动记录：Action
         ══════════════════════════════════════════════════════ -->
    <record id="action_esim_balance_log" model="ir.actions.act_window">
        <field name="name">余额变动记录</field>
        <field name="res_model">esim.balance.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_esim_balance_log_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                暂无余额变动记录
            </p>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         合作伙伴表单扩展：添加 eSIM 余额信息
         ══════════════════════════════════════════════════════ -->
    <record id="view_partner_form_esim_balance" model="ir.ui.view">
        <field name="name">res.partner.form.esim.balance</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button name="action_view_esim_balance_logs" type="object"
                        class="oe_stat_button" icon="fa-usd"
                        groups="esim_access.group_esim_user">
                    <div class="o_stat_info">
                        <field name="esim_balance" class="o_stat_value" widget="monetary"
                               options="{'currency_id': False}"/>
                        <span class="o_stat_text">eSIM 余额</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button name="%(action_esim_balance_topup_wizard)d" type="action"
                        class="oe_stat_button" icon="fa-plus-circle"
                        context="{'default_partner_id': id}"
                        invisible="not id"
                        groups="esim_access.group_esim_manager">
                    <span class="o_stat_text">充值</span>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
