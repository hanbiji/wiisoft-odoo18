<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ── 列表视图 ──────────────────────────────────────── -->
    <record id="view_esim_profile_list" model="ir.ui.view">
        <field name="name">esim.profile.list</field>
        <field name="model">esim.profile</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'active'"
                  decoration-info="state == 'ready'"
                  decoration-warning="state == 'suspended'"
                  decoration-danger="state == 'revoked'"
                  decoration-muted="state == 'expired'">
                <field name="iccid"/>
                <field name="esim_tran_no" optional="hide"/>
                <field name="partner_id"/>
                <field name="package_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-info="state == 'ready'"
                       decoration-warning="state == 'suspended'"
                       decoration-danger="state == 'revoked'"/>
                <field name="esim_status" optional="hide"/>
                <field name="smdp_status" optional="hide"/>
                <field name="total_volume"/>
                <field name="used_volume"/>
                <field name="remaining_volume"/>
                <field name="expired_time"/>
            </list>
        </field>
    </record>

    <!-- ── 表单视图 ──────────────────────────────────────── -->
    <record id="view_esim_profile_form" model="ir.ui.view">
        <field name="name">esim.profile.form</field>
        <field name="model">esim.profile</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_refresh_status" type="object"
                            string="刷新状态" class="btn-primary"
                            invisible="state in ('revoked', 'expired')"/>
                    <button name="action_suspend" type="object"
                            string="挂起" class="btn-warning"
                            invisible="state not in ('ready', 'active')"
                            confirm="确定要挂起此 eSIM 吗？"/>
                    <button name="action_revoke" type="object"
                            string="吊销" class="btn-danger"
                            invisible="state in ('revoked',)"
                            confirm="吊销操作不可逆，确定要吊销此 eSIM 吗？"
                            groups="esim_access.group_esim_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,ready,active"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_topups" type="object"
                                class="oe_stat_button" icon="fa-bolt"
                                invisible="topup_count == 0">
                            <field name="topup_count" widget="statinfo" string="充值"/>
                        </button>
                    </div>
                    <group>
                        <group string="eSIM 信息">
                            <field name="iccid"/>
                            <field name="esim_tran_no"/>
                            <field name="partner_id"/>
                            <field name="order_id"/>
                            <field name="package_id"/>
                            <field name="imsi" groups="esim_access.group_esim_manager"/>
                            <field name="eid" groups="esim_access.group_esim_manager"/>
                            <field name="apn"/>
                        </group>
                        <group string="状态与激活">
                            <field name="esim_status"/>
                            <field name="smdp_status"/>
                            <field name="qr_code" widget="CopyClipboardChar"/>
                            <field name="qr_code_url" widget="url"/>
                            <field name="expired_time"/>
                        </group>
                    </group>
                    <group string="流量使用">
                        <group>
                            <field name="total_volume"/>
                            <field name="used_volume"/>
                            <field name="remaining_volume"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="充值记录" name="topups">
                            <field name="topup_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="package_id"/>
                                    <field name="amount"/>
                                    <field name="state" widget="badge"/>
                                    <field name="topup_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── 搜索视图 ──────────────────────────────────────── -->
    <record id="view_esim_profile_search" model="ir.ui.view">
        <field name="name">esim.profile.search</field>
        <field name="model">esim.profile</field>
        <field name="arch" type="xml">
            <search>
                <field name="iccid"/>
                <field name="esim_tran_no"/>
                <field name="partner_id"/>
                <field name="package_id"/>
                <filter name="filter_active" string="使用中" domain="[('state', '=', 'active')]"/>
                <filter name="filter_ready" string="待激活" domain="[('state', '=', 'ready')]"/>
                <filter name="filter_suspended" string="已挂起" domain="[('state', '=', 'suspended')]"/>
                <separator/>
                <group expand="0" string="分组">
                    <filter name="group_partner" string="客户" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_state" string="状态" context="{'group_by': 'state'}"/>
                    <filter name="group_package" string="套餐" context="{'group_by': 'package_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────── -->
    <record id="action_esim_profile" model="ir.actions.act_window">
        <field name="name">eSIM 档案</field>
        <field name="res_model">esim.profile</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_esim_profile_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                暂无 eSIM 档案
            </p>
            <p>订单完成后将自动创建 eSIM 档案。</p>
        </field>
    </record>

</odoo>
